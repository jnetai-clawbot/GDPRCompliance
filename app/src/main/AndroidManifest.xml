<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:name=".GDPRApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.GDPRCompliance">
        <activity
            android:name=".ui.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity android:name=".ui.AddActivityActivity" android:parentActivityName=".ui.MainActivity" />
        <activity android:name=".ui.ActivityDetailActivity" android:parentActivityName=".ui.MainActivity" />
        <activity android:name=".ui.ChecklistActivity" android:parentActivityName=".ui.MainActivity" />
        <activity android:name=".ui.BreachLogActivity" android:parentActivityName=".ui.MainActivity" />
        <activity android:name=".ui.DashboardActivity" android:parentActivityName=".ui.MainActivity" />
        <activity android:name=".ui.AboutActivity" android:parentActivityName=".ui.MainActivity" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data android:name="android.support.FILE_PROVIDER_PATHS" android:resource="@xml/file_paths" />
        </provider>
    </application>

</manifest>